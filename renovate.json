{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchManagers": ["mise"],
      "groupName": "mise tools",
      "additionalBranchPrefix": "",
      "postUpgradeTasks": {
        "commands": ["mise lock"],
        "fileFilters": ["mise.lock"],
        "executionMode": "branch"
      }
    }
  ]
}
